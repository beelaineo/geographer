# Next.js Sanity Client
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity Studio
SANITY_STUDIO_PROJECT_ID=your-project-id
SANITY_STUDIO_DATASET=production

# Redesign/Staging dataset workflow
# For redesign work, point Studio and staging web app at a non-production dataset
# such as `redesign` or `staging`:
# NEXT_PUBLIC_SANITY_DATASET=redesign
# SANITY_STUDIO_DATASET=redesign

# Optional: Read token for preview mode in Next.js
SANITY_READ_TOKEN=

# Optional: Secret for on-demand revalidation endpoints
SANITY_REVALIDATE_SECRET=
